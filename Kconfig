menuconfig PMW3610_ALT
  bool "PMW3610 mouse optical sensor"
  select SPI
  depends on INPUT
  depends on DT_HAS_PIXART_PMW3610_ALT_ENABLED
  help
      Enable PMW3610 mouse optical sensor.

if PMW3610_ALT

config INPUT_PMW3610_INIT_PRIORITY
    int "PMW3610 initialization priority"
    default INPUT_INIT_PRIORITY

config PMW3610_ALT_SWAP_XY
  bool "Swap the X/Y axis of PMW3610 sensor"

config PMW3610_ALT_INVERT_X
  bool "Invert the X axis of PMW3610 sensor"

config PMW3610_ALT_INVERT_Y
  bool "Invert the Y axis of PMW3610 sensor"

config PMW3610_ALT_ORIENTATION_180
  bool "Rotate sensor 180 degrees (invert both X and Y axes)"
  help
    Equivalent to CONFIG_PMW3610_ORIENTATION_180 in the original driver.
    When enabled, both X and Y axes are inverted regardless of the
    invert-x / invert-y device tree properties.

config PMW3610_ALT_CPI_DIVIDOR
  int "CPI divisor"
  default 1
  range 1 12
  help
    Divides the CPI value set in the device tree node.
    1 means no division (default).

config PMW3610_ALT_SCROLL_TICK
  int "Scroll tick - accumulated delta before reporting one scroll unit"
  default 20
  range 1 255
  help
    Number of sensor delta counts to accumulate before emitting one
    WHEEL / HWHEEL scroll event. Higher value = slower scroll.

config PMW3610_ALT_INVERT_SCROLL_X
  bool "Invert horizontal scroll (HWHEEL) direction"

config PMW3610_ALT_INVERT_SCROLL_Y
  bool "Invert vertical scroll (WHEEL) direction"

config PMW3610_ALT_SNIPE_CPI_DIVIDOR
  int "CPI divisor applied in snipe-layers"
  default 4
  range 1 12
  help
    Divides cursor movement in snipe-layers before reporting.
    Remainders are accumulated and carried over between reports.
    Higher value = slower, more precise cursor.

config PMW3610_ALT_INIT_POWER_UP_EXTRA_DELAY_MS
  int "Extra power up init delay (ms)"
  default 0


config PMW3610_ALT_SMART_ALGORITHM
  bool "Enable an algorithm of PMW3610 to enhance surface coverage"
  default y

config PMW3610_ALT_RUN_DOWNSHIFT_TIME_MS
    int "PMW3610's default RUN mode downshift time"
    default 128
    range 13 3264

config PMW3610_ALT_REST1_DOWNSHIFT_TIME_MS
    int "PMW3610's default REST1 mode downshift time"
    default 5000

config PMW3610_ALT_REST2_DOWNSHIFT_TIME_MS
    int "PMW3610's default REST2 mode downshift time"
    default 17000

config PMW3610_ALT_REST1_SAMPLE_TIME_MS
    int "PMW3610's sample time in REST1 stage"
    default 40

config PMW3610_ALT_REST2_SAMPLE_TIME_MS
    int "PMW3610's sample time in REST2 stage"
    default 100

config PMW3610_ALT_REST3_SAMPLE_TIME_MS
    int "PMW3610's sample time in REST3 stage"
    default 500

config PMW3610_ALT_MOVEMENT_THRESHOLD
    int "Minimum movement threshold to report"
    default 0

module = PMW3610_ALT
module-str = PMW3610_ALT
source "${ZEPHYR_BASE}/subsys/logging/Kconfig.template.log_config"

endif #PMW3610_ALT
